SELECT
    Booking_ID,
    Rec_Name,
    Rec_Address,
    Rec_Pin,
    Rec_Mobile,
    Par_Weight_Gram,
    Par_Contents_Description,
    Par_Delivery_Type,
    Par_Packing_Preference,
    Par_PickupTime,
    Par_DropoffTime,
    Par_ServiceCost,
    Par_PaymentTime
FROM tbl_Booking
WHERE Booking_ID = 1001;


SELECT TOP 10
    b.Booking_ID,
    u.FullName,
    u.Rec_Address AS Address,
    b.Rec_Name,
    b.Rec_Address,
    b.Par_PickupTime AS DateOfBooking,
    b.Par_Status
FROM tbl_Booking b
INNER JOIN tbl_UserProfile u
    ON b.User_ID = u.User_ID
WHERE b.User_ID = 1
ORDER BY b.Booking_ID DESC;


SELECT
    b.Booking_ID,
    u.FullName,
    u.Rec_Address AS Address,
    b.Rec_Name,
    b.Rec_Address,
    b.Par_PickupTime,
    b.Par_DropoffTime,
    b.Par_Status
FROM tbl_Booking b
INNER JOIN tbl_UserProfile u
ON b.User_ID = u.User_ID
WHERE b.Booking_ID = @BookingID;


UPDATE tbl_Booking
SET
    Par_PickupTime = @PickupTime,
    Par_DropoffTime = @DropoffTime
WHERE Booking_ID = @BookingID;

SELECT
    b.Booking_ID,
    u.FullName,
    u.Rec_Address AS Address,
    b.Rec_Name,
    b.Rec_Address,
    b.Par_PickupTime AS DateOfBooking,
    b.Par_Status
FROM tbl_Booking b
INNER JOIN tbl_UserProfile u
ON b.User_ID = u.User_ID
WHERE b.Booking_ID = @BookingID;


UPDATE tbl_Booking
SET Par_Status = @Status
WHERE Booking_ID = @BookingID;


SELECT
    b.User_ID AS CustomerID,
    b.Booking_ID,
    b.Par_PickupTime AS BookingDate,
    b.Rec_Name AS ReceiverName,
    b.Rec_Address AS DeliveredAddress,
    b.Par_ServiceCost AS Amount,
    b.Par_Status AS Status
FROM tbl_Booking b
WHERE b.User_ID = @UserID
ORDER BY b.Par_PickupTime DESC;



SELECT
    Booking_ID,
    User_ID,
    Rec_Name,
    Rec_Address,
    Par_ServiceCost,
    Par_Status
FROM tbl_Booking
WHERE Par_Status = 'Delivered'
ORDER BY Booking_ID DESC;
